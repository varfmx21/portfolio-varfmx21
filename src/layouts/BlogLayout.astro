---
import Layout from './Layout.astro';
import SectionContainer from '../components/SectionContainer.astro';

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <main>
    <SectionContainer class="py-20 pb-10">
      <article class="blog-content">
        <!-- Header del post -->
        <header class="mb-8 pb-8 border-b border-white/10">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">{frontmatter.title}</h1>
          
          <div class="flex items-center gap-4 text-sm text-gray-400">
            {frontmatter.author && <span>Por {frontmatter.author}</span>}
            {frontmatter.date && (
              <time datetime={frontmatter.date.toISOString()}>
                {frontmatter.date.toLocaleDateString('es-ES', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric' 
                })}
              </time>
            )}
          </div>

          {frontmatter.description && (
            <p class="text-xl lg:text-2xl text-gray-300 mt-6">{frontmatter.description}</p>
          )}

          {frontmatter.tags && frontmatter.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-6">
              {frontmatter.tags.map((tag: string) => (
                <span class="px-3 py-1 bg-white/5 hover:bg-white/10 rounded-full text-sm transition">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <!-- Contenido del post -->
        <div class="text-gray-200">
          <slot />
        </div>

        <!-- Botón volver -->
        <div class="mt-12 pt-8 border-t border-white/10">
          <a 
            href="/blog" 
            class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 transition"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Volver al blog
          </a>
        </div>
      </article>
    </SectionContainer>
  </main>
</Layout>

<style is:global>
  /* Estilos para el contenido Markdown */
  .blog-content h2 {
    font-size: 1.875rem;
    font-weight: 700;
    color: white;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .blog-content h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .blog-content p {
    color: rgb(209 213 219);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  
  .blog-content a {
    color: rgb(34 211 238);
    text-decoration: underline;
    transition: color 0.2s;
  }
  
  .blog-content a:hover {
    color: rgb(103 232 249);
  }
  
  .blog-content code {
    background-color: rgba(255, 255, 255, 0.1);
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
    color: rgb(103 232 249);
    font-size: 0.875rem;
  }
  
  .blog-content pre {
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
  }
  
  .blog-content pre code {
    background-color: transparent;
    padding: 0;
    color: rgb(229 231 235);
  }
  
  .blog-content ul, 
  .blog-content ol {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
    color: rgb(209 213 219);
  }
  
  .blog-content li {
    margin-bottom: 0.5rem;
  }
  
  .blog-content blockquote {
    border-left: 4px solid rgb(6 182 212);
    padding-left: 1rem;
    font-style: italic;
    color: rgb(156 163 175);
    margin: 1rem 0;
  }

  .blog-content img {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .blog-content hr {
    border-color: rgba(255, 255, 255, 0.1);
    margin: 2rem 0;
  }

  .blog-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .blog-content th {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1rem;
    text-align: left;
    font-weight: 600;
    color: white;
  }

  .blog-content td {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1rem;
    color: rgb(209 213 219);
  }

  .blog-content strong {
    font-weight: 700;
    color: white;
  }

  .blog-content em {
    font-style: italic;
  }
</style>
